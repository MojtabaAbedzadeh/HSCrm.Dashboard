@using HSCrm.Dashboard.Models
@using HSCrm.Dashboard.Services
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@inject IAuthorizationService AuthorizationService

@{
    var selected = ViewData["selected"]?.ToString() ?? "";
    var menus = SidebarMenuProvider.GetMenus();
}

@functions {
    public static async Task<bool> IsMenuVisibleAsync(
        SidebarMenuItem menu,
        ClaimsPrincipal user,
        IAuthorizationService authorizationService)
    {
        if (!string.IsNullOrEmpty(menu.PermissionKey))
        {
            var authorized = await authorizationService.AuthorizeAsync(
            user,
            $"Permission:{menu.PermissionKey}"
        );

            if (!authorized.Succeeded)
            {
                return false;
            }
        }

        if (menu.Children != null && menu.Children.Count > 0)
        {
            foreach (var child in menu.Children)
            {
                if (await IsMenuVisibleAsync(child, user, authorizationService))
                    return true;
            }
            return false;
        }
        return true;
    }
}

<div class="ec-left-sidebar ec-bg-sidebar">
    <div id="sidebar" class="sidebar ec-sidebar-footer">
        <div class="ec-brand">
            <a href="index.html" title="BilgiSoft">
                <img class="ec-brand-icon" src="~/assets/img/logo/ec-site-logo.png" alt="">
                <span class="ec-brand-name text-truncate">بیلگی سافت</span>
            </a>
        </div>

        <div class="ec-navigation" data-simplebar>
            <ul class="nav sidebar-inner" id="sidebar-menu">
                @foreach (var menu in menus)
                {
                    var menuVisible = await IsMenuVisibleAsync(menu, User, AuthorizationService);
                    if (!menuVisible)
                    {
                        continue;
                    }

                    if (menu.Children.Count == 0)
                    {
                        <li class="@(selected == menu.Key ? "active" : null)">
                            <a class="sidenav-item-link" href="@menu.Url">
                                <i class="@menu.Icon"></i>
                                <span class="nav-text">@menu.Title</span>
                            </a>
                        </li>
                    }
                    else
                    {
                        var visibleChildren = new List<SidebarMenuItem>();
                        foreach (var child in menu.Children)
                        {
                            if (await IsMenuVisibleAsync(child, User, AuthorizationService))
                            {
                                visibleChildren.Add(child);
                            }
                        }

                        if (visibleChildren.Count == 0)
                        {
                            continue;
                        }

                        <li class="has-sub @(selected.StartsWith(menu.Key) ? "active expand" : null)">
                            <a class="sidenav-item-link" href="javascript:void(0)">
                                <i class="@menu.Icon"></i>
                                <span class="nav-text">@menu.Title</span>
                                <b class="caret"></b>
                            </a>

                            <div class="collapse" style="display:@(selected.StartsWith(menu.Key) ? "block" : "none")">
                                <ul class="sub-menu">
                                    @foreach (var child in visibleChildren)
                                    {
                                        <li class="@(selected == child.Key ? "active" : null)">
                                            <a class="sidenav-item-link" href="@child.Url">
                                                <span class="nav-text">@child.Title</span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
</div>