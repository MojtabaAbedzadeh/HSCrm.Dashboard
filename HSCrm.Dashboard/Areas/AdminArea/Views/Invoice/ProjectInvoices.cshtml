@using HSCrm.BussinessLagic.Tools
@model IEnumerable<SalesInvoiceModel>

@{
    ViewData["AdminTitle"] = "فاکتورها";
    ViewData["selected"] = "invoice_by_project";

    string ApiAddress = ViewBag.ApiAddress;
    string UId = ViewBag.UserId;
    string TId = ViewBag.TenantId;
}

@section styles {
    <link href="~/assets/plugins/data-tables/datatables.bootstrap5.min.css" rel="stylesheet">
    <link href="~/assets/plugins/data-tables/responsive.datatables.min.css" rel="stylesheet">
    <link href="~/assets/css/ekka.css" id="ekka-css" rel="stylesheet">
    <link href="~/lib/persiandate/persian-datepicker.css" rel="stylesheet" />
}

<div class="breadcrumb-wrapper breadcrumb-contacts">
    <div>
        <h1>لیست فاکتورها</h1>
        <p class="breadcrumbs"><span><a href="index.html">خانه</a></span> <span><i class="mdi mdi-chevron-left"></i></span>فاکتور</p>
    </div>
    @if (ViewBag.FiscalYearStatus == "0")
    {
        <div><button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpense">افزودن فاکتور</button></div>
    }
</div>
@if (ViewBag.FiscalYearStatus != "0")
{
    <div class="alert alert-primary col-lg-8" role="alert" style="margin-top:40px; color:#084298;">
        توجه!
        <br>
        سال مالی انتخاب شده بسته می باشد! شما فقط قادر به مشاهده گزارشات سیستم هستید.
    </div>
}
<div class="row">
    <div class="col-12">
        <div class="ec-vendor-list card card-default">
            <div class="card-body">
                <div class="table-responsive-md">
                    <div id="responsive-data-table_wrapper" class="dataTables_wrapper dt-bootstrap5 no-footer">
                        <table id="responsive-data-table" class="table dataTable no-footer" aria-describedby="responsive-data-table_info">
                            <thead>
                                <tr>
                                    <th>شماره</th>
                                    <th>تاریخ</th>
                                    <th>عنوان پروژه</th>
                                    <th>مشتری</th>
                                    <th>نوع فاکتور</th>
                                    <th>جمع فاکتور</th>
                                    <th>فعالیت</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Number</td>
                                        <td>@ConvertDate.ConvertMiladiToShamsi(item.IssueDate, "yyyy/MM/dd")</td>
                                        <td>@item.Project.ProjectTitle</td>
                                        <td>@item.Project.ProjectTitle</td>
                                        <td>
                                            <span class="badge @(item.Status == 1 ? "bg-success" : "bg-info")">
                                                @(item.Status == 1 ? "فاکتور نهایی" : "پیش فاکتور")
                                            </span>
                                        </td>
                                        <td>@item.Total</td>
                                        <td>
                                            <div class="btn-group mb-1">
                                                <button type="button" class="btn btn-outline-success" onclick="showInvoiceDetail('@item.Id')">جزئیات</button>
                                                <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" data-display="static">
                                                    <span class="sr-only">اطلاعات</span>
                                                </button>
                                                @if (ViewBag.FiscalYearStatus == "0")
                                                {
                                                    <div class="dropdown-menu">
                                                        <a class="dropdown-item" href="#" onclick="showUpdateModal(@item.Id)">ویرایش</a>
                                                        <a class="dropdown-item" href="#" onclick="deleteExpense(@item.Id)">حذف</a>
                                                        @if (item.Status == 0)
                                                        {
                                                            <div class="dropdown-divider"></div>
                                                            <a class="dropdown-item text-primary" href="javascript:void(0)" onclick="confirmInvoice('@item.Id')">
                                                                <i class="mdi mdi-file"></i>
                                                                تبدیل به فاکتور نهایی
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="dropdown-menu">
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section AdminScripts {
    <script src="~/lib/sweetalert/sweetalert2.js"></script>
    <script>
        function confirmInvoice(invoiceId) {

            swal({
                title: "تأیید فاکتور",
                text: "آیا از تبدیل پیش‌فاکتور به فاکتور نهایی مطمئن هستید؟",
                type: 'warning',
                showCancelButton: true,
                allowOutsideClick: false,
                confirmButtonColor: "green",
                cancelButtonColor: "#d33",
                confirmButtonText: "بله، تأیید شود",
                cancelButtonText: "انصراف"
            }).then(function (result) {

                if (!result.value)
                    return false;

                var formData = new FormData();
                formData.append("invoiceId", invoiceId);
                console.log(onformdata);
                $.ajax({
                    type: 'POST',
                    url: '@ApiAddress' + 'SalesInvoice/ConfirmInvoice',
                    processData: false,
                    contentType: false,
                    dataType: 'json',
                    data: formData,
                    success: function (xhr) {

                        if (xhr.statusCode == 200) {

                            swal({
                                title: "تأیید فاکتور",
                                text: "فاکتور با موفقیت نهایی شد!",
                                type: 'success',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            setTimeout(function () {
                                window.location.reload();
                            }, 1500);
                        }

                        else if (xhr.statusCode == 400) {

                            swal({
                                title: "خطا",
                                text: "پارامترهای ارسالی معتبر نیست!",
                                type: 'error',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            return false;
                        }

                        else if (xhr.statusCode == 404) {

                            swal({
                                title: "خطا",
                                text: "فاکتور مورد نظر یافت نشد!",
                                type: 'error',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            return false;
                        }

                        else if (xhr.statusCode == 409) {

                            swal({
                                title: "خطا",
                                text: "این فاکتور قبلاً نهایی شده است!",
                                type: 'error',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            return false;
                        }

                        else if (xhr.statusCode == 500) {

                            swal({
                                title: "خطا",
                                text: "خطایی در انجام عملیات رخ داده است!",
                                type: 'error',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            return false;
                        }
                    },
                    error: function (err) {

                        swal({
                            title: "خطا",
                            text: err.responseText || "خطایی در ارتباط با سرور رخ داده است!",
                            type: 'error',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            confirmButtonText: "باشه",
                            timer: 1500,
                        });

                    }
                });

            });
        }
    </script>

    <script>
        function showInvoiceDetail(invoiceId) {

            $.ajax({
                type: 'GET',
                url: '@ApiAddress' + 'SalesInvoice/GetInvoiceDetail?invoiceId=' + invoiceId,
                dataType: 'json',
                success: function (xhr) {

                    if (xhr.statusCode == 200) {

                        const items = xhr.data;

                        if (!items || items.length === 0) {

                            swal({
                                title: "جزئیات فاکتور",
                                text: "آیتمی برای این فاکتور ثبت نشده است!",
                                type: 'warning',
                                showCancelButton: false,
                                allowOutsideClick: false,
                                confirmButtonColor: "green",
                                confirmButtonText: "باشه",
                                timer: 1500,
                            });

                            return false;
                        }

                        let itemsHtml = '';

                        items.forEach(item => {

                            itemsHtml +=
                                "<tr>" +
                                "<td>" + item.productId + "</td>" +
                                "<td>" + item.quantity + "</td>" +
                                "<td>" + item.unitPriceSell.toLocaleString() + "</td>" +
                                "<td>" + item.lineTotal.toLocaleString() + "</td>" +
                                "</tr>";

                        });

                        swal({
                            title: "جزئیات آیتم‌های فاکتور",
                            html:
                                "<div class='table-responsive'>" +
                                "<table class='table table-bordered text-center'>" +
                                "<thead>" +
                                "<tr>" +
                                "<th>شناسه محصول</th>" +
                                "<th>تعداد</th>" +
                                "<th>قیمت واحد</th>" +
                                "<th>جمع</th>" +
                                "</tr>" +
                                "</thead>" +
                                "<tbody>" +
                                itemsHtml +
                                "</tbody>" +
                                "</table>" +
                                "</div>",
                            type: 'info',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            confirmButtonText: "باشه",
                            width: '700px'
                        });

                    }

                    else if (xhr.statusCode == 400) {

                        swal({
                            title: "خطا",
                            text: "پارامترهای ارسالی معتبر نیست!",
                            type: 'error',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            confirmButtonText: "باشه",
                            timer: 1500,
                        });

                        return false;
                    }

                    else if (xhr.statusCode == 404) {

                        swal({
                            title: "خطا",
                            text: "جزئیات فاکتور مورد نظر یافت نشد!",
                            type: 'error',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            confirmButtonText: "باشه",
                            timer: 1500,
                        });

                        return false;
                    }

                    else if (xhr.statusCode == 500) {

                        swal({
                            title: "خطا",
                            text: "خطایی در دریافت اطلاعات فاکتور رخ داده است!",
                            type: 'error',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            confirmButtonText: "باشه",
                            timer: 1500,
                        });

                        return false;
                    }
                },
                error: function (err) {

                    swal({
                        title: "خطا",
                        text: err.responseText || "خطایی در ارتباط با سرور رخ داده است!",
                        type: 'error',
                        showCancelButton: false,
                        allowOutsideClick: false,
                        confirmButtonColor: "green",
                        confirmButtonText: "باشه",
                        timer: 1500,
                    });

                }
            });
        }
    </script>
    <script>
        window.AppContext = {
            apiAddress: '@ViewBag.ApiAddress',
            tenantId: '@ViewBag.TenantId',
            userId: '@ViewBag.UserId'
        };
    </script>
    <script src="~/js/views/invoice/sale-invoice.js"></script>
}