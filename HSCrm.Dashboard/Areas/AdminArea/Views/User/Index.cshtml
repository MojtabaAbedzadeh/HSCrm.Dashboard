@section AdminScripts {
    <script>
        $("#btnUserSubmit").on('click', function (e) {
            e.preventDefault();
            var formData = new FormData($("#frmUser")[0]);

            console.log(formData);

            $.ajax({
                type: 'POST',
                url: '@ApiAddress' + 'User/CreateUser',
                processData: false,
                contentType: false,
                dataType: "json",
                data: formData,
                success: function (xhr) {
                    if (xhr.statusCode == 200) {
                        // ثبت موفق اطلاعات
                        swal({
                            title: "ثبت اطلاعات",
                            text: "ثبت اطلاعات با موفقیت انجام شد!",
                            type: 'success',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            timer: 1500
                        });
                        $('#addUser').modal('hide');                        
                        window.location.reload();
                    }                    
                },
                error: function (xhr) {
                    if (xhr.statusCode == 500) {
                        swal({
                            title: "خطا",
                            text: "خطا در سرور!",
                            type: 'success',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            timer: 1500
                        });
                        return false;
                    } else if (xhr.statusCode == 400) {
                         swal({
                            title: "خطا",
                            text: "پارامترهای ارسالی معتبر نیست!",
                            type: 'success',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            timer: 1500
                        });
                        return false;
                    }
                    else if (xhr.statusCode == 409) {
                        swal({
                            title: "خطا",
                            text: "اطلاعات تکراری می‌باشد!",
                            type: 'success',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            timer: 1500
                        });
                        return false;
                    }
                    else if (xhr.status === 401) {
                        swal({
                            title: "خطا",
                            text: "شما برای انجام این عملیات دسترسی لازم را ندارید!",
                            type: 'success',
                            showCancelButton: false,
                            allowOutsideClick: false,
                            confirmButtonColor: "green",
                            timer: 1500
                        });
                    }
                }
            });
        });

    </script>

    <script>
        function showUpdateModal(userId) {

            $.ajax({
                type: 'GET',
                url: '@ApiAddress' + 'User/GetUserById?userId=' + userId,
                dataType: 'json',
                success: function (xhr) {

                    $("#UserId").val(xhr.data.id);
                    $("#UserFirstName").val(xhr.data.userFirstName);
                    $("#UserLastName").val(xhr.data.userLastName);
                    $("#PhoneNumber").val(xhr.data.phoneNumber);
                    $("#Email").val(xhr.data.email);
                    $("#UserImageUrl").val(xhr.data.userImageUrl);

                    $("#imgUser").attr("src", xhr.data.userImageUrl);

                    if (xhr.data.userGender) {
                        $("#editUser input[name='UserGender'][value='true']").prop("checked", true);
                    } else {
                        $("#editUser input[name='UserGender'][value='false']").prop("checked", true);
                    }

                    var modal = new bootstrap.Modal(document.getElementById('editUser'));
                    modal.show();
                }
            });
        }


        $("#btnUserUpdate").on('click', function (e) {
            e.preventDefault();

            var model = {
                UserId: $("#UserId").val(),
                UserFirstName: $("#UserFirstName").val(),
                UserLastName: $("#UserLastName").val(),
                UserName: $("#UserName").val(),
                PhoneNumber: $("#PhoneNumber").val(),
                Email: $("#Email").val(),
                UserImageUrl: $("#UserImageUrl").val(),
                UserGender: $("input[name='UserGender']:checked").val() === "true"
            };

            $.ajax({
                type: 'PUT',
                url: '@ApiAddress' + 'User/UpdateUser',
                contentType: 'application/json',
                data: JSON.stringify(model),
                success: function (xhr) {
                    if (xhr.statusCode == 200) {
                        swal({
                        title: "ویرایش اطلاعات",
                        text: "اطلاعات با موفقیت ویرایش شد!",
                        type: 'success',
                        showCancelButton: false,
                        allowOutsideClick: false,
                        confirmButtonColor: "green",
                        confirmButtonText: "باشه",
                        timer: 1500,
                    });
                        location.reload();
                    } else {
                        Swal({
                            icon: "error",
                            title: xhr.message
                        });
                    }
                }
            });
        });
    </script>

    <!--User Image Upload (Insert)-->
    <script>
        $("#UserImagesC").change(function () {
            var data = new FormData;
            var file = $("#UserImagesC").get(0);
            var files = file.files;

            for (var i = 0; i < files.length; i++) {
                data.append('imagearray', files[i]);
            }

            $.ajax({
                type: 'Post',
                url: '@ApiAddress' + 'FileUpload/UserImageUpload',
                data: data,
                contentType: false,
                processData: false
            }).done(function (xhr) {
                if (xhr.statusCode == '200') {
                    $("#imgUserC").attr('src', xhr.message);
                    $("#divMessage").removeClass('hidden');
                    $("#divMessage").css("color", "green");
                    $("#divMessage").html("آپلود انجام شد.");
                    $("#UserImageUrlC").val(xhr.message);
                }
                else if (xhr.statusCode != '200') {
                    $("#divMessage").removeClass('hidden');
                    $("#divMessage").css("color", "red");
                    $("#divMessage").html("در حین آپلود مشکلی رخ داد.");

                }
            });
        });
    </script>

    <!--User Image Upload (Update)-->
    <script>
        $("#UserImages").change(function () {
            var data = new FormData;
            var file = $("#UserImages").get(0);
            var files = file.files;

            for (var i = 0; i < files.length; i++) {
                data.append('imagearray', files[i]);
            }

            $.ajax({
                type: 'Post',
                url: '@ApiAddress' + 'FileUpload/UserImageUpload',
                data: data,
                contentType: false,
                processData: false
            }).done(function (xhr) {
                if (xhr.statusCode == '200') {
                    $("#imgUser").attr('src', xhr.message);
                    $("#divMessage").removeClass('hidden');
                    $("#divMessage").css("color", "green");
                    $("#divMessage").html("آپلود انجام شد.");
                    $("#UserImageUrl").val(xhr.message);
                }
            }).fail(function (data, textStatus, xhr) {
                if (xhr.status != '200') {
                    $("#divMessage").removeClass('hidden');
                    $("#divMessage").css("color", "red");
                    $("#divMessage").html("در حین آپلود مشکلی رخ داد.");
                }
            });
        });
    </script>
}